# Example environment variables for ai-study-assistant
# Remove any sensitive keys from version control. Add your real
# values to a local `.env` file (not committed).

# Groq API key (replace with your key)
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace embedding model for the RAG pipeline.
# Smaller default keeps Render memory usage lower.
EMBEDDING_MODEL=sentence-transformers/paraphrase-MiniLM-L3-v2

# Optional: override Groq model name
#GROQ_MODEL=your_groq_model_name_here
